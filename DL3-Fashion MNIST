// 1
import numpy as np
import matplotlib.pyplot as plt
from tensorflow.keras.datasets import fashion_mnist
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Conv2D, MaxPooling2D, Dense, Flatten, Dropout
from tensorflow.keras.utils import to_categorical



//2
(trainX, trainY), (testX, testY) = fashion_mnist.load_data()

print(trainX.shape, testX.shape)



//3 - Reshape Dataset
trainX = trainX.reshape((60000, 28, 28, 1))
testX = testX.reshape((10000, 28, 28, 1))



//4 - Normalize Data
trainX = trainX.astype('float32') / 255.0
testX = testX.astype('float32') / 255.0




//5 - One Hot Encoding
from tensorflow.keras.utils import to_categorical

trainY = to_categorical(trainY)
testY = to_categorical(testY)


//6

from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Conv2D, MaxPooling2D
from tensorflow.keras.layers import Dense, Flatten, Dropout


//7 - Build CNN Model
model = Sequential()

# Convolution Block 1
model.add(Conv2D(32, (3,3), activation='relu', input_shape=(28,28,1)))
model.add(MaxPooling2D((2,2)))

# Convolution Block 2
model.add(Conv2D(64, (3,3), activation='relu'))
model.add(MaxPooling2D((2,2)))

# Flatten
model.add(Flatten())

# Fully Connected Layer
model.add(Dense(128, activation='relu'))
model.add(Dropout(0.5))

# Output Layer
model.add(Dense(10, activation='softmax'))



//8 - Compile Model
model.compile(
    optimizer='adam',
    loss='categorical_crossentropy',
    metrics=['accuracy']
)



//9 - Train the model
history = model.fit(
    trainX, trainY,
    epochs=10,
    batch_size=32,
    validation_data=(testX, testY)
)



#First we imported required libraries.
Then we loaded Fashion MNIST dataset.
After that we reshaped and normalized images.
Labels were converted into categorical format.
Then we created CNN model using Conv2D, MaxPooling, Flatten, Dense and Dropout layers.
Model was compiled using Adam optimizer and categorical crossentropy loss function.
Then we trained the model using fit() and finally evaluated accuracy using evaluate().



//10 - Evaluate Model
loss, accuracy = model.evaluate(testX, testY)
print("Test Accuracy:", accuracy)


