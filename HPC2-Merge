#include <iostream>     // Used for input and output operations
#include <vector>       // Used to store dynamic array
#include <cstdlib>      // Used for rand() function
#include <ctime>        // Used for time() function
#include <omp.h>        // OpenMP library for parallel programming

using namespace std;

#define SIZE 10000      // Total number of elements in array

// ============================
// Sequential Bubble Sort
// ============================

// Normal bubble sort using single thread
void bubbleSortSeq(vector<int>& arr) {
    int n = arr.size();     // Get size of array

    // Outer loop controls number of passes
    for (int i = 0; i < n - 1; i++) {

        // Inner loop compares adjacent elements
        for (int j = 0; j < n - i - 1; j++) {

            // Swap if left element is greater
            if (arr[j] > arr[j + 1]) {
                swap(arr[j], arr[j + 1]);   // Exchange elements
            }
        }
    }
}

// ============================
// Parallel Bubble Sort
// ============================

// Bubble sort using OpenMP parallel threads
void bubbleSortParallel(vector<int>& arr) {
    int n = arr.size();

    // Repeat sorting phases
    for (int i = 0; i < n; i++) {

        // Even indexed phase
        #pragma omp parallel for   // Parallelize loop using threads
        for (int j = 0; j < n - 1; j += 2) {

            // Compare and swap adjacent even pairs
            if (arr[j] > arr[j + 1]) {
                swap(arr[j], arr[j + 1]);
            }
        }

        // Odd indexed phase
        #pragma omp parallel for   // Parallelize odd comparisons
        for (int j = 1; j < n - 1; j += 2) {

            // Compare and swap adjacent odd pairs
            if (arr[j] > arr[j + 1]) {
                swap(arr[j], arr[j + 1]);
            }
        }
    }
}

// ============================
// Merge Function
// ============================

// Function to merge two sorted halves
void merge(vector<int>& arr, int l, int m, int r) {

    // Store left half in temporary array
    vector<int> left(arr.begin() + l, arr.begin() + m + 1);

    // Store right half in temporary array
    vector<int> right(arr.begin() + m + 1, arr.begin() + r + 1);

    int i = 0, j = 0, k = l;

    // Compare elements and merge in sorted order
    while (i < left.size() && j < right.size()) {

        // Insert smaller element into original array
        if (left[i] <= right[j])
            arr[k++] = left[i++];
        else
            arr[k++] = right[j++];
    }

    // Copy remaining left elements if any
    while (i < left.size())
        arr[k++] = left[i++];

    // Copy remaining right elements if any
    while (j < right.size())
        arr[k++] = right[j++];
}

// ============================
// Sequential Merge Sort
// ============================

// Merge sort using recursive divide and conquer
void mergeSortSeq(vector<int>& arr, int l, int r) {

    // Continue only if left index smaller than right
    if (l < r) {

        // Find middle index
        int m = (l + r) / 2;

        // Recursively sort left half
        mergeSortSeq(arr, l, m);

        // Recursively sort right half
        mergeSortSeq(arr, m + 1, r);

        // Merge sorted halves
        merge(arr, l, m, r);
    }
}

// ============================
// Parallel Merge Sort
// ============================

// Merge sort using OpenMP parallel sections
void mergeSortParallel(vector<int>& arr, int l, int r, int depth) {

    // Continue only if valid partition exists
    if (l < r) {

        // Find middle index
        int m = (l + r) / 2;

        // Stop creating threads after depth becomes zero
        if (depth <= 0) {

            // Use sequential merge sort
            mergeSortSeq(arr, l, m);
            mergeSortSeq(arr, m + 1, r);

        } else {

            // Create parallel sections
            #pragma omp parallel sections
            {

                // First thread sorts left half
                #pragma omp section
                mergeSortParallel(arr, l, m, depth - 1);

                // Second thread sorts right half
                #pragma omp section
                mergeSortParallel(arr, m + 1, r, depth - 1);
            }
        }

        // Merge both sorted halves
        merge(arr, l, m, r);
    }
}

// ============================
// Utility Functions
// ============================

// Generate random numbers in array
void generateRandom(vector<int>& arr) {

    // Fill array with random values
    for (int& x : arr) {
        x = rand() % 100000;
    }
}

// ============================
// Main Function
// ============================

int main() {

    // Create array and temporary array
    vector<int> arr(SIZE), temp;

    srand(time(0));   // Seed random number generator

    generateRandom(arr);   // Generate random elements

    double start, end;

    // -------- Sequential Bubble Sort --------

    temp = arr;   // Copy original array

    start = omp_get_wtime();   // Start timer

    bubbleSortSeq(temp);   // Perform sequential bubble sort

    end = omp_get_wtime();   // Stop timer

    cout << "Sequential Bubble Sort Time: "
         << (end - start) << " sec\n";

    // -------- Parallel Bubble Sort --------

    temp = arr;   // Copy original array

    start = omp_get_wtime();   // Start timer

    bubbleSortParallel(temp);   // Perform parallel bubble sort

    end = omp_get_wtime();   // Stop timer

    cout << "Parallel Bubble Sort Time: "
         << (end - start) << " sec\n";

    // -------- Sequential Merge Sort --------

    temp = arr;   // Copy original array

    start = omp_get_wtime();   // Start timer

    mergeSortSeq(temp, 0, SIZE - 1);   // Perform sequential merge sort

    end = omp_get_wtime();   // Stop timer

    cout << "Sequential Merge Sort Time: "
         << (end - start) << " sec\n";

    // -------- Parallel Merge Sort --------

    temp = arr;   // Copy original array

    start = omp_get_wtime();   // Start timer

    mergeSortParallel(temp, 0, SIZE - 1, 4); // Perform parallel merge sort

    end = omp_get_wtime();   // Stop timer

    cout << "Parallel Merge Sort Time: "
         << (end - start) << " sec\n";

    return 0;   // End program successfully
}


